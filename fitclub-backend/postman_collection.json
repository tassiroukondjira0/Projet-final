{
  "info": {
    "name": "FitClub API",
    "description": "Collection Postman pour tester l'API FitClub",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4100/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "courseId",
      "value": "course_1"
    },
    {
      "key": "bookingId",
      "value": ""
    },
    {
      "key": "paymentId",
      "value": ""
    },
    {
      "key": "coachId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Awa Diop\",\n  \"email\": \"awa@example.com\",\n  \"password\": \"motdepasse123\",\n  \"phone\": \"+221701234567\",\n  \"birthDate\": \"1995-04-12\",\n  \"address\": \"Rue Mz 83\",\n  \"city\": \"Dakar\",\n  \"country\": \"Sénégal\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"awa@example.com\",\n  \"password\": \"motdepasse123\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"awa@example.com\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Awa Diop\",\n  \"email\": \"awa@example.com\",\n  \"phone\": \"+221709876543\",\n  \"birthDate\": \"1995-04-12\",\n  \"address\": \"Rue Mz 83\",\n  \"city\": \"Dakar\",\n  \"country\": \"Sénégal\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/dashboard/overview"
          }
        },
        {
          "name": "Clients (admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/dashboard/clients"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "List Courses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/courses"
          }
        },
        {
          "name": "Get Course By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/courses/{{courseId}}"
          }
        }
      ]
    },
    {
      "name": "Contact",
      "item": [
        {
          "name": "Send Contact Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/contact",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Awa\",\n  \"lastName\": \"Diop\",\n  \"email\": \"awa@example.com\",\n  \"message\": \"Bonjour, je souhaite plus d'informations.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"{{courseId}}\",\n  \"subscriptionType\": \"monthly\"\n}"
            }
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/bookings/me"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Process Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/payments/process",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"paymentMethod\": \"wave\",\n  \"phoneNumber\": \"+221701234567\"\n}"
            }
          }
        },
        {
          "name": "Get Payment Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/payments/{{paymentId}}"
          }
        }
      ]
    },
    {
      "name": "Coaches",
      "item": [
        {
          "name": "Create Coach (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/coaches",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Coach Awa\",\n  \"email\": \"awa.coach@fitclub.sn\",\n  \"password\": \"motdepasse123\",\n  \"phone\": \"+221701234567\",\n  \"bio\": \"Specialiste endurance et cardio.\",\n  \"specialty\": \"Endurance & cardio\"\n}"
            }
          }
        },
        {
          "name": "List Coaches (admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/coaches"
          }
        },
        {
          "name": "My Courses (coach)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/courses/mine"
          }
        },
        {
          "name": "Course Bookings (coach/admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/bookings/course/{{courseId}}"
          }
        }
      ]
    }
  ]
}