# Port du serveur — le frontend est configuré par défaut sur http://localhost:4100/api
# (voir VITE_API_BASE_URL dans le .env du frontend), gardez ce port en local.
PORT=4100

# Connexion MongoDB (MongoDB Atlas recommandé pour le déploiement)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/fitclub

# Clé secrète pour signer les tokens JWT
JWT_SECRET=change_this_secret_key_before_deploying
JWT_EXPIRES_IN=7d

# URL du frontend déployé (pour la configuration CORS)
# — sans "/" final (l'origine envoyée par le navigateur n'en a jamais)
# — plusieurs domaines possibles, séparés par des virgules
#   (ex: domaine de prod Vercel + URLs de preview + localhost en dev)
CLIENT_URL=http://localhost:5173,https://final-projet-front-end-full-stack12.vercel.app

# Environnement
NODE_ENV=development
